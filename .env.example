# Production site URL (used for metadata / Open Graph)
NEXT_PUBLIC_SITE_URL=https://relife.dev

# Primary support contact (footer, legal pages)
NEXT_PUBLIC_SUPPORT_EMAIL=team@relife.dev

# Privacy / general inquiries (optional override)
NEXT_PUBLIC_PRIVACY_EMAIL=team@relife.dev

# Data-rights requests (Privacy Policy §5); defaults to support@relife.app in code if unset
NEXT_PUBLIC_DATA_RIGHTS_EMAIL=support@relife.app

# App Store, Google Play, Seeker (Solana Mobile)
NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/us/app/relife-todo-habit-tracker/id6749513808
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.yerasyl.todoapp
NEXT_PUBLIC_SEEKER_STORE_URL=https://solanamobile.com/
